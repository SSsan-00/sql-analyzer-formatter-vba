      "sql_lines": ["INSERT INTO user_archive(ユーザーID, 氏名, 状態)", "SELECT", "    tb1.ユーザーID", "    , tb1.氏名", "    , tb1.状態", "FROM", "    users AS tb1", "WHERE", "    tb1.削除日時 < @archive_before"],
      "tables": { "user_archive": "ユーザーアーカイブ", "tb1": "ユーザー" }
    },
    {
      "id": "SEL-046",
      "sql_lines": ["DELETE tb1", "FROM", "    users AS tb1", "WHERE", "    tb1.削除日時 < @delete_before", "    AND tb1.状態 = 'INACTIVE'"],
      "tables": { "tb1": "ユーザー" }
    },
    {
      "id": "SEL-047",
      "sql_lines": ["UPDATE tb1", "SET", "    状態 = @status", "    , 更新日時 = sysdatetime()", "FROM", "    users AS tb1", "    INNER JOIN orders AS tb2", "        ON tb1.ユーザーID = tb2.注文ユーザーID", "WHERE", "    tb2.状態 = @order_status"],
      "tables": { "tb1": "ユーザー", "tb2": "注文" }
    },
    {
      "id": "SEL-048",
      "sql_lines": ["select", "    v.ユーザーID", "    , v.氏名 ", "from", "    (values (1, 'Alice'), (2, 'Bob')) as v(user_id, name) ", "order by", "    v.ユーザーID"],
      "tables": { "v": "(和名未取得)" }
    },
    {
      "id": "SEL-049",
      "sql_lines": ["select", "    tb1.ユーザーID", "    , case", "        when tb1.状態 = 'ACTIVE' then", "            case", "                when tb1.ランクコード = 'VIP' then '優良'", "                else '通常'", "            end", "        when tb1.状態 = 'LOCKED' then '停止'", "        else '無効'", "    end as user_category ", "from", "    users as tb1"],
      "tables": { "tb1": "ユーザー" }
    },
    {
      "id": "SEL-050",
      "sql_lines": ["select", "    case", "        when tb1.金額 >= 10000 then 'HIGH'", "        else 'NORMAL'", "    end as amount_band", "    , count(tb1.注文ID) as order_count ", "from", "    orders as tb1 ", "group by", "    case", "        when tb1.金額 >= 10000 then 'HIGH'", "        else 'NORMAL'", "    end"],
      "tables": { "tb1": "注文" }
    },
    {
      "id": "SEL-051",
      "sql_lines": ["select", "    tb1.ユーザーID", "    , tb1.氏名", "    , tb1.状態 ", "from", "    users as tb1 ", "order by", "    case", "        when tb1.状態 = 'ACTIVE' then 0", "        when tb1.状態 = 'LOCKED' then 1", "        else 2", "    end", "    , tb1.ユーザーID"],
      "tables": { "tb1": "ユーザー" }
    },
    {
      "id": "SEL-052",
      "sql_lines": ["select", "    tb1.ユーザーID", "    , tb1.氏名", "    , tb1.削除日時 ", "from", "    users as tb1 ", "order by", "    iif(tb1.削除日時 is null, 0, 1)", "    , tb1.ユーザーID desc"],
      "tables": { "tb1": "ユーザー" }
    },
    {
      "id": "SEL-053",
      "sql_lines": ["select", "    tb1.ユーザーID", "    , tb1.氏名 ", "from", "    users as tb1 ", "where", "    ( ", "        ( ", "            tb1.状態 in ('ACTIVE', 'LOCKED') ", "            and (tb1.メール like @domain or tb1.氏名 like @name)", "        ) ", "        or ( ", "            tb1.状態 = 'PENDING' ", "            and tb1.削除日時 is null", "        )", "    ) ", "    and ( ", "        tb1.作成日時 >= dateadd(day, - 30, @base_date) ", "        or ( ", "            tb1.更新日時 is null ", "            and tb1.メール is not null", "        )", "    ) ", "    and not ( ", "        tb1.ユーザーID between @excluded_from and @excluded_to ", "        or coalesce(tb1.上司ID, 0) = @excluded_manager_id", "    )"],
      "tables": { "tb1": "ユーザー" }
    },
    {
      "id": "SEL-054",
      "sql_lines": ["select", "    tb1.ユーザーID", "    , tb1.氏名", "    , sq.合計金額", "    , sq.最終注文日時 ", "from", "    users as tb1 ", "    inner join (", "        select", "            tb2.注文ユーザーID", "            , sum(tb2.金額) as total_amount", "            , max(tb2.注文日時) as last_order_at ", "        from", "            orders as tb2 ", "        where", "            tb2.状態 in ('PAID', 'SHIPPED') ", "        group by", "            tb2.注文ユーザーID ", "        having", "            sum(tb2.金額) >= @min_total", "    ) as sq", "        on tb1.ユーザーID = sq.注文ユーザーID", "        and sq.最終注文日時 >= dateadd(day, -90, @base_date) ", "where", "    tb1.状態 = 'ACTIVE' ", "order by", "    sq.合計金額 desc"],
      "tables": { "tb1": "ユーザー", "tb2": "注文", "sq": "(和名未取得)" }
    },
    {
      "id": "SEL-055",
      "sql_lines": ["select", "    tb1.ユーザーID", "    , tb1.氏名 ", "from", "    users as tb1 ", "where", "    exists (", "        select", "1", "        from", "            orders as tb2 ", "        where", "            tb2.注文ユーザーID = tb1.ユーザーID", "            and tb2.金額 > (", "                select", "                    avg(tb3.金額) ", "                from", "                    orders as tb3 ", "                where", "                    tb3.状態 = tb2.状態", "            )", "    )"],
      "tables": { "tb1": "ユーザー", "tb2": "注文", "tb3": "注文" }
    },
    {
      "id": "SEL-056",
      "review_status": "暫定確定（ハイブリッド出力はユーザーレビュー未実施）",
      "sql_lines": ["insert ", "into user_summary(ユーザーID, 表示名, 注文件数, 作成日時, 作成元区分) ", "select", "    tb1.ユーザーID", "    , coalesce(tb1.氏名, tb1.メール) as display_name", "    , count(tb2.注文ID) as order_count", "    , sysdatetime()", "    , 'BATCH' ", "from", "    users as tb1 ", "    left join orders as tb2", "        on tb1.ユーザーID = tb2.注文ユーザーID", "        and tb2.状態 = 'PAID' ", "where", "    tb1.状態 = 'ACTIVE' ", "group by", "    tb1.ユーザーID", "    , tb1.氏名", "    , tb1.メール ", "having", "    count(tb2.注文ID) >= @min_order_count"],
      "tables": { "user_summary": "ユーザー集計", "tb1": "ユーザー", "tb2": "注文" }
    },
    {
      "id": "SEL-057",
      "sql_lines": ["select", "    tb1.ユーザーID", "    , tb1.氏名", "    , tb1.状態 ", "from", "    users as tb1 ", "where", "    case", "        when tb1.状態 = 'ACTIVE' and tb1.削除日時 is null then 1", "        when tb1.状態 = 'PENDING' and tb1.作成日時 >= dateadd(day, -7, @base_date) then 1", "        else 0", "    end = 1"],
      "tables": { "tb1": "ユーザー" }
    },
    {
      "id": "SEL-058",
      "sql_lines": ["select distinct", "    tb1.状態 ", "from", "    users as tb1 ", "order by", "    tb1.状態"],
      "tables": { "tb1": "ユーザー" }
    },
    {
      "id": "SEL-059",
      "sql_lines": ["select", "    tb1.ユーザーID", "    , tb1.メール ", "into user_export ", "from", "    users as tb1"],
      "tables": { "user_export": "ユーザー出力", "tb1": "ユーザー" }
    },
    {
      "id": "SEL-060",
      "review_status": "暫定確定（ユーザーレビュー未実施）",
      "sql_lines": ["insert ", "into users(ユーザーID, 氏名, 状態, 作成日時) ", "values (@user_id, @name, 'ACTIVE', sysdatetime())"],
      "tables": { "users": "ユーザー" }
    },
