        { "table_id": "tb2", "table_name_ja": "注文", "field_id": "created_at", "field_name_ja": "注文日時" },
        { "table_id": "tb2", "table_name_ja": "注文", "field_id": "status", "field_name_ja": "状態" },
        { "table_id": "sq", "table_name_ja": "(和名未取得)", "field_id": "user_id", "field_name_ja": "注文ユーザーID" },
        { "table_id": "sq", "table_name_ja": "(和名未取得)", "field_id": "total_amount", "field_name_ja": "合計金額" },
