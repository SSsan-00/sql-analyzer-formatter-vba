    {
      "id": "SEL-056",
      "title": "拡張INSERT SELECT",
      "sql_lines": [
        "insert ",
        "into user_summary(user_id, display_name, order_count, created_at, source_type) ",
        "select",
        "    tb1.user_id",
        "    , coalesce(tb1.name, tb1.email) as display_name",
        "    , count(tb2.order_id) as order_count",
        "    , sysdatetime()",
        "    , 'BATCH' ",
        "from",
        "    users as tb1 ",
        "    left join orders as tb2",
        "        on tb1.user_id = tb2.user_id",
        "        and tb2.status = 'PAID' ",
        "where",
        "    tb1.status = 'ACTIVE' ",
        "group by",
        "    tb1.user_id",
        "    , tb1.name",
        "    , tb1.email ",
        "having",
        "    count(tb2.order_id) >= @min_order_count"
      ],
      "definitions": [
        { "table_id": "user_summary", "table_name_ja": "ユーザー集計", "field_id": "user_id", "field_name_ja": "ユーザーID" },
        { "table_id": "user_summary", "table_name_ja": "ユーザー集計", "field_id": "display_name", "field_name_ja": "表示名" },
        { "table_id": "user_summary", "table_name_ja": "ユーザー集計", "field_id": "order_count", "field_name_ja": "注文件数" },
