    {
      "id": "SEL-053",
      "title": "多段の複雑な条件式",
      "sql_lines": [
        "select",
        "    tb1.user_id",
        "    , tb1.name ",
        "from",
        "    users as tb1 ",
        "where",
        "    ( ",
        "        ( ",
        "            tb1.status in ('ACTIVE', 'LOCKED') ",
        "            and (tb1.email like @domain or tb1.name like @name)",
        "        ) ",
        "        or ( ",
        "            tb1.status = 'PENDING' ",
        "            and tb1.deleted_at is null",
        "        )",
        "    ) ",
        "    and ( ",
        "        tb1.created_at >= dateadd(day, - 30, @base_date) ",
        "        or ( ",
        "            tb1.updated_at is null ",
        "            and tb1.email is not null",
        "        )",
        "    ) ",
        "    and not ( ",
        "        tb1.user_id between @excluded_from and @excluded_to ",
        "        or coalesce(tb1.manager_id, 0) = @excluded_manager_id",
        "    )"
