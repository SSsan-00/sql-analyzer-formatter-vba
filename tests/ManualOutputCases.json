    {
      "id": "SEL-054",
      "title": "複雑な派生テーブルJOIN",
      "sql_lines": [
        "select",
        "    tb1.user_id",
        "    , tb1.name",
        "    , sq.total_amount",
        "    , sq.last_order_at ",
        "from",
        "    users as tb1 ",
        "    inner join (",
        "        select",
        "            tb2.user_id",
        "            , sum(tb2.amount) as total_amount",
        "            , max(tb2.created_at) as last_order_at ",
        "        from",
        "            orders as tb2 ",
        "        where",
        "            tb2.status in ('PAID', 'SHIPPED') ",
        "        group by",
        "            tb2.user_id ",
        "        having",
        "            sum(tb2.amount) >= @min_total",
        "    ) as sq",
        "        on tb1.user_id = sq.user_id",
        "        and sq.last_order_at >= dateadd(day, -90, @base_date) ",
        "where",
        "    tb1.status = 'ACTIVE' ",
        "order by",
        "    sq.total_amount desc"
      ],
      "definitions": [
