      "id": "SEL-061",
      "title": "CASEを含む複雑なSELECT INTO",
      "sql_lines": [
        "select",
        "    tb1.user_id",
        "    , coalesce(tb1.name, tb1.email) as display_name",
        "    , count(tb2.order_id) as order_count",
        "    , case",
        "        when count(tb2.order_id) >= @priority_order_count ",
        "            then 'PRIORITY' ",
        "        when count(tb2.order_id) > 0 ",
        "            then 'STANDARD' ",
        "        else 'NONE' ",
        "    end as order_rank",
        "    , sysdatetime() as created_at",
        "    , 'BATCH' as source_type ",
        "into user_summary ",
        "from",
        "    users as tb1 ",
        "    left join orders as tb2",
        "        on tb1.user_id = tb2.user_id ",
        "        and tb2.status = 'PAID' ",
        "where",
        "    tb1.status = 'ACTIVE' ",
        "group by",
        "    tb1.user_id",
        "    , tb1.name",
        "    , tb1.email ",
        "having",
        "    count(tb2.order_id) >= @min_order_count"
